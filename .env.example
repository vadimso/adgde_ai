# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Database Configuration
DATABASE_URL=postgresql://export:export@postgres:5432/exports

# Redis Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_BACKEND_URL=redis://redis:6379/1

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=changeme_secure_password_here
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme_secure_password_here
MINIO_CONSOLE_ADDRESS=:9001

# PostgreSQL Configuration
POSTGRES_USER=export
POSTGRES_PASSWORD=changeme_secure_password_here
POSTGRES_DB=exports

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Environment
ENV=development
